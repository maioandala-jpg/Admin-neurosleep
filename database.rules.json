{
  "rules": {
    ".read": false,
    ".write": false,

    "media": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'COLOQUE_AQUI_O_UID_DO_ADMIN'"
    },

    "alarm-sounds": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'COLOQUE_AQUI_O_UID_DO_ADMIN'"
    },

    "fcm-tokens": {
      ".read": false,
      "$token": {
        ".write": true,
        ".validate": "newData.val() === true"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
